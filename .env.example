# StackLive API Configuration

# Backend API URL
# Update this with your actual StackLive backend URL
# For local development, use: http://localhost:3000
# For production, use: https://api.stacklive.app
EXPO_PUBLIC_API_URL=https://api.stacklive.app

# Example for local development:
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Example for staging:
# EXPO_PUBLIC_API_URL=https://staging-api.stacklive.app
